+/// Enable nftables' `auto-merge` on every interval set definition in the batch.
+///
+/// The `nftables` crate's `Set` type can't express auto-merge, but libnftables
+/// accepts the JSON key (nftables >= 1.1.0, i.e. OpenWrt >= 24.10). Without it,
+/// each insert into an interval set does an O(set size) overlap check, making a
+/// full banlist O(N^2). Element adds (no "set" object) are left untouched.
+fn enable_auto_merge(value: &mut serde_json::Value) {
+    let Some(objects) = value
+        .get_mut("nftables")
+        .and_then(serde_json::Value::as_array_mut)
+    else {
+        return;
+    };
+    for object in objects {
+        // Set definitions look like {"add": {"set": { ... }}}.
+        let Some(set) = object
+            .get_mut("add")
+            .and_then(|add| add.get_mut("set"))
+            .and_then(serde_json::Value::as_object_mut)
+        else {
+            continue;
+        };
+        let is_interval = set
+            .get("flags")
+            .and_then(serde_json::Value::as_array)
+            .is_some_and(|flags| flags.iter().any(|f| f.as_str() == Some("interval")));
+        if is_interval {
+            set.insert("auto-merge".to_owned(), serde_json::Value::Bool(true));
+        }
+    }
+}
